PORT=8080
CORS_ORIGINS=http://localhost:5173,https://cakb-dev.firebaseapp.com,https://ponya1226.github.io
MAX_IMAGE_BYTES=5242880
REQUIRE_FIREBASE_AUTH=true
REQUIRE_HOUSEHOLD_MEMBERSHIP=true
# Optional additional email restriction. Household membership is the primary authorization check.
ALLOWED_AUTH_EMAILS=
# Optional shared token. If set, clients must send X-caKb-OCR-Token.
OCR_SHARED_TOKEN=
# Per authenticated user and Cloud Run instance. Set 0 to disable.
OCR_RATE_LIMIT_MAX_REQUESTS=10
OCR_RATE_LIMIT_WINDOW_SECONDS=60
# Project-wide monthly proxy request cap stored in Firestore. Set 0 to disable.
OCR_MONTHLY_LIMIT=900
