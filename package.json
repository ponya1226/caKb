{
  "name": "local-kakeibo-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "tsc --noEmit",
    "test": "vitest run src",
    "test:rules": "npx --yes firebase-tools@14.16.0 emulators:exec --only firestore --project demo-cakb \"vitest run tests/firestore.rules.test.ts\"",
    "deploy:hosting": "npm run build && npx --yes firebase-tools@14.16.0 deploy --only hosting --project cakb-dev",
    "deploy:rules": "npx --yes firebase-tools@14.16.0 deploy --only firestore:rules --project cakb-dev"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  }
}
